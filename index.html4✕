<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>PWA Test App</title>
    <style>
        body { margin: 0; background: #111; color: white; font-family: sans-serif; overflow: hidden; display: flex; flex-direction: column; align-items: center; }
        .canvas { width: 90vw; margin: 10px 0; background: #222; position: relative; overflow: hidden; display: flex; align-items: center; justify-content: center; touch-action: none; }
        #nav-container { height: 30vh; }
        #main-container { height: 50vh; background: #333; }
        .preview-img { position: absolute; will-change: transform; pointer-events: none; }
        .crop-box { position: absolute; border: 2px solid blue; box-sizing: border-box; }
        .nav-box { position: absolute; border: 1px solid red; background: rgba(255, 0, 0, 0.2); pointer-events: none; }
        /* 辺の当たり判定用ハンドル */
        .handle { position: absolute; background: transparent; }
        .h-n { top: -15px; left: 0; right: 0; height: 30px; cursor: ns-resize; }
        .h-s { bottom: -15px; left: 0; right: 0; height: 30px; cursor: ns-resize; }
        .h-e { right: -15px; top: 0; bottom: 0; width: 30px; cursor: ew-resize; }
        .h-w { left: -15px; top: 0; bottom: 0; width: 30px; cursor: ew-resize; }
        .footer { margin-top: 10px; }
        .file-btn { display: inline-block; width: 60px; height: 60px; background: white; border-radius: 50%; font-size: 30px; line-height: 60px; cursor: pointer; text-align: center; color: black; }
    </style>
</head>
<body>
    <div id="nav-container" class="canvas"><img id="nav-img" class="preview-img"><div id="nav-box" class="nav-box"></div></div>
    <div id="main-container" class="canvas">
        <img id="main-img" class="preview-img">
        <div id="crop-box" class="crop-box">
            <div class="handle h-n" data-edge="n"></div><div class="handle h-s" data-edge="s"></div>
            <div class="handle h-e" data-edge="e"></div><div class="handle h-w" data-edge="w"></div>
        </div>
    </div>
    <div class="footer"><input type="file" id="file-input" accept="image/*" hidden><label for="file-input" class="file-btn">📁</label></div>

    <script>
        const navImg = document.getElementById('nav-img'), mainImg = document.getElementById('main-img'), navBox = document.getElementById('nav-box'), cropBox = document.getElementById('crop-box');
        let imgData = { naturalW: 0, naturalH: 0, baseScale: 1 };
        let selection = { x: 0, y: 0, w: 0, h: 0 }; // 画像内ピクセル座標
        let view = { zoom: 1, offsetX: 0, offsetY: 0 }; // 表示用状態
        let touch = { mode: '', startDist: 0, startZoom: 1, lastX: 0, lastY: 0, edge: '' };

        document.getElementById('file-input').onchange = (e) => {
            const reader = new FileReader();
            reader.onload = (ev) => {
                navImg.src = mainImg.src = ev.target.result;
                mainImg.onload = () => {
                    imgData.naturalW = mainImg.naturalWidth; imgData.naturalH = mainImg.naturalHeight;
                    // 初期：画像全体に枠
                    selection = { x: 0, y: 0, w: imgData.naturalW, h: imgData.naturalH };
                    resetView();
                };
            };
            reader.readAsDataURL(e.target.files[0]);
        };

        function resetView() {
            const container = document.getElementById('main-container').getBoundingClientRect();
            imgData.baseScale = Math.min(container.width / imgData.naturalW, container.height / imgData.naturalH);
            view = { zoom: 1, offsetX: 0, offsetY: 0 };
            updateDisplay();
        }

        const mainContainer = document.getElementById('main-container');
        mainContainer.ontouchstart = (e) => {
            if (e.touches.length === 2) {
                touch.mode = 'zoom';
                touch.startDist = Math.hypot(e.touches[0].pageX - e.touches[1].pageX, e.touches[0].pageY - e.touches[1].pageY);
                touch.startZoom = view.zoom;
            } else if (e.touches.length === 1) {
                const target = e.target;
                if (target.classList.contains('handle')) {
                    touch.mode = 'edit';
                    touch.edge = target.dataset.edge;
                } else {
                    touch.mode = 'scroll';
                }
                touch.lastX = e.touches[0].pageX; touch.lastY = e.touches[0].pageY;
            }
        };

        mainContainer.ontouchmove = (e) => {
            e.preventDefault();
            if (touch.mode === 'zoom') {
                const dist = Math.hypot(e.touches[0].pageX - e.touches[1].pageX, e.touches[0].pageY - e.touches[1].pageY);
                view.zoom = touch.startZoom * (dist / touch.startDist);
            } else if (touch.mode === 'scroll') {
                view.offsetX += (e.touches[0].pageX - touch.lastX);
                view.offsetY += (e.touches[0].pageY - touch.lastY);
                touch.lastX = e.touches[0].pageX; touch.lastY = e.touches[0].pageY;
            } else if (touch.mode === 'edit') {
                const scale = imgData.baseScale * view.zoom;
                const dx = (e.touches[0].pageX - touch.lastX) / scale;
                const dy = (e.touches[0].pageY - touch.lastY) / scale;
                if (touch.edge === 'n') { selection.y += dy; selection.h -= dy; }
                if (touch.edge === 's') { selection.h += dy; }
                if (touch.edge === 'e') { selection.w += dx; }
                if (touch.edge === 'w') { selection.x += dx; selection.w -= dx; }
                touch.lastX = e.touches[0].pageX; touch.lastY = e.touches[0].pageY;
            }
            updateDisplay();
        };

        mainContainer.ontouchend = () => {
            if (touch.mode === 'edit') fitToScreen();
            touch.mode = '';
        };

        function fitToScreen() {
            // 選択範囲をキャンバス中央にフィットさせる計算（簡易版）
            const container = document.getElementById('main-container').getBoundingClientRect();
            const targetScale = Math.min(container.width / selection.w, container.height / selection.h) / imgData.baseScale;
            
            // アニメーション（今回は瞬時に切り替え、後でTween実装可）
            view.zoom = targetScale;
            view.offsetX = -(selection.x + selection.w/2 - imgData.naturalW/2) * imgData.baseScale * view.zoom;
            view.offsetY = -(selection.y + selection.h/2 - imgData.naturalH/2) * imgData.baseScale * view.zoom;
            updateDisplay();
        }

        function updateDisplay() {
            const scale = imgData.baseScale * view.zoom;
            const style = `translate(${view.offsetX}px, ${view.offsetY}px) scale(${scale})`;
            mainImg.style.transform = style;
            
            // 作業枠の表示更新
            cropBox.style.width = (selection.w * scale) + 'px';
            cropBox.style.height = (selection.h * scale) + 'px';
            cropBox.style.left = `calc(50% + ${view.offsetX + (selection.x - imgData.naturalW/2) * scale}px)`;
            cropBox.style.top = `calc(50% + ${view.offsetY + (selection.y - imgData.naturalH/2) * scale}px)`;

            // ナビ枠の表示更新（ナビ側は常に全体表示）
            const nRect = navImg.getBoundingClientRect();
            const nScale = nRect.width / imgData.naturalW;
            navBox.style.width = (selection.w * nScale) + 'px';
            navBox.style.height = (selection.h * nScale) + 'px';
            navBox.style.left = (navImg.offsetLeft + selection.x * nScale) + 'px';
            navBox.style.top = (navImg.offsetTop + selection.y * nScale) + 'px';
        }
    </script>
</body>
</html>
