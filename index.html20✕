<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>PWA Test App - Dot Precise</title>
    <style>
        body { margin: 0; background: #111; overflow: hidden; display: flex; flex-direction: column; align-items: center; }
        .canvas { width: 90vw; margin: 10px 0; background: #222; position: relative; overflow: hidden; touch-action: none; }
        #nav-container { height: 30vh; }
        #main-container { height: 50vh; background: #333; }
        .smooth-move { transition: transform 0.3s ease-out, left 0.3s ease-out, top 0.3s ease-out, width 0.3s ease-out, height 0.3s ease-out; }
        
        /* ★ ぼかしを防ぐ設定 */
        #main-img, #nav-img { 
            position: absolute; top: 0; left: 0; transform-origin: 0 0; pointer-events: none; display: none;
            image-rendering: -moz-crisp-edges;
            image-rendering: pixelated; /* Chrome, Android, Edge 用 */
        }
        
        .crop-box { position: absolute; border: 2px solid blue; box-sizing: border-box; z-index: 10; display: none; pointer-events: none; }
        .nav-box { position: absolute; border: 1px solid red; background: rgba(255, 0, 0, 0.2); z-index: 10; pointer-events: none; display: none; }
        .handle { position: absolute; background: rgba(0, 100, 255, 0.05); pointer-events: auto; }
        .h-n, .h-s { left: 0; right: 0; height: 100px; }
        .h-e, .h-w { top: 0; bottom: 0; width: 100px; }
        .h-n { top: -50px; } .h-s { bottom: -50px; }
        .h-e { right: -50px; } .h-w { left: -50px; }
        .footer { margin-top: 10px; }
        .file-btn { display: inline-block; width: 60px; height: 60px; background: white; border-radius: 50%; font-size: 30px; line-height: 60px; cursor: pointer; text-align: center; color: black; }
    </style>
</head>
<body>
    <div id="nav-container" class="canvas"><img id="nav-img" alt=""><div id="nav-box" class="nav-box"></div></div>
    <div id="main-container" class="canvas">
        <img id="main-img" alt="">
        <div id="crop-box" class="crop-box">
            <div id="hn" class="handle h-n" data-edge="n"></div>
            <div id="hs" class="handle h-s" data-edge="s"></div>
            <div id="he" class="handle h-e" data-edge="e"></div>
            <div id="hw" class="handle h-w" data-edge="w"></div>
        </div>
    </div>
    <div class="footer"><input type="file" id="file-input" accept="image/*" hidden><label for="file-input" class="file-btn">📁</label></div>

    <script>
        const navImg = document.getElementById('nav-img'), mainImg = document.getElementById('main-img'), navBox = document.getElementById('nav-box'), cropBox = document.getElementById('crop-box'), mCont = document.getElementById('main-container'), nCont = document.getElementById('nav-container');
        let img = { w: 0, h: 0, isLoaded: false }, view = { x: 0, y: 0, scale: 1 }, crop = { x: 0, y: 0, w: 0, h: 0 }, touch = { mode: '', lastX: 0, lastY: 0, edge: '' };

        document.getElementById('file-input').onchange = (e) => {
            const file = e.target.files; if (!file) return;
            const reader = new FileReader(); reader.onload = (ev) => {
                navImg.src = mainImg.src = ev.target.result;
                mainImg.onload = () => {
                    img.w = mainImg.naturalWidth; img.h = mainImg.naturalHeight; img.isLoaded = true;
                    const mRect = mCont.getBoundingClientRect();
                    view.scale = Math.min(mRect.width / img.w, mRect.height / img.h);
                    view.x = (mRect.width - img.w * view.scale) / 2; view.y = (mRect.height - img.h * view.scale) / 2;
                    crop = { x: view.x, y: view.y, w: img.w * view.scale, h: img.h * view.scale };
                    mainImg.style.display = navImg.style.display = cropBox.style.display = navBox.style.display = 'block';
                    update(false);
                };
            }; reader.readAsDataURL(file);
        };

        mCont.addEventListener('touchstart', (e) => {
            if (!img.isLoaded) return; [mainImg, cropBox].forEach(el => el.classList.remove('smooth-move'));
            if (e.target.classList.contains('handle')) { touch.mode = 'edit'; touch.edge = e.target.dataset.edge; }
            else { touch.mode = 'scroll'; }
            touch.lastX = e.touches.pageX; touch.lastY = e.touches.pageY;
        }, { passive: false });

        mCont.addEventListener('touchmove', (e) => {
            if (!img.isLoaded || !touch.mode) return; e.preventDefault();
            const dx = e.touches.pageX - touch.lastX, dy = e.touches.pageY - touch.lastY;
            
            if (touch.mode === 'scroll') {
                view.x += dx; view.y += dy;
            } else if (touch.mode === 'edit') {
                const imgR = view.x + img.w * view.scale, imgB = view.y + img.h * view.scale;
                // ★ 1ピクセル制限（画像本来の1ピクセル分を最小値とする）
                const minCrop = 1 * view.scale;

                if (touch.edge === 'n') {
                    let d = Math.max(dy, view.y - crop.y);
                    if (crop.h - d < minCrop) d = crop.h - minCrop; // 最小高さ制限
                    crop.y += d; crop.h -= d;
                }
                if (touch.edge === 's') {
                    crop.h = Math.max(minCrop, Math.min(crop.h + dy, imgB - crop.y));
                }
                if (touch.edge === 'e') {
                    crop.w = Math.max(minCrop, Math.min(crop.w + dx, imgR - crop.x));
                }
                if (touch.edge === 'w') {
                    let d = Math.max(dx, view.x - crop.x);
                    if (crop.w - d < minCrop) d = crop.w - minCrop; // 最小幅制限
                    crop.x += d; crop.w -= d;
                }
            }
            touch.lastX = e.touches.pageX; touch.lastY = e.touches.pageY; update(false);
        }, { passive: false });

        mCont.addEventListener('touchend', () => {
            if (!img.isLoaded) return; [mainImg, cropBox].forEach(el => el.classList.add('smooth-move'));
            if (touch.mode === 'edit') fitToCrop(); else snapBack();
            touch.mode = '';
        });

        function snapBack() {
            const minX = crop.x + crop.w - (img.w * view.scale), maxX = crop.x, minY = crop.y + crop.h - (img.h * view.scale), maxY = crop.y;
            view.x = Math.max(minX, Math.min(view.x, maxX)); view.y = Math.max(minY, Math.min(view.y, maxY)); update(true);
        }

        function fitToCrop() {
            const mRect = mCont.getBoundingClientRect(), relX = (crop.x - view.x) / view.scale, relY = (crop.y - view.y) / view.scale, relW = crop.w / view.scale, relH = crop.h / view.scale;
            view.scale = Math.min(mRect.width / relW, mRect.height / relH);
            view.x = (mRect.width / 2) - (relX + relW / 2) * view.scale; view.y = (mRect.height / 2) - (relY + relH / 2) * view.scale;
            crop.w = relW * view.scale; crop.h = relH * view.scale; crop.x = (mRect.width - crop.w) / 2; crop.y = (mRect.height - crop.h) / 2; update(true);
        }

        function update(smooth) {
            if (!img.isLoaded) return;
            mainImg.style.transform = `translate(${view.x}px, ${view.y}px) scale(${view.scale})`;
            cropBox.style.left = crop.x + 'px'; cropBox.style.top = crop.y + 'px';
            cropBox.style.width = crop.w + 'px'; cropBox.style.height = crop.h + 'px';

            const hn = document.getElementById('hn'), hs = document.getElementById('hs'), he = document.getElementById('he'), hw = document.getElementById('hw');
            if (crop.w < crop.h) { he.style.zIndex = hw.style.zIndex = "1000"; hn.style.zIndex = hs.style.zIndex = "500"; }
            else { hn.style.zIndex = hs.style.zIndex = "1000"; he.style.zIndex = hw.style.zIndex = "500"; }

            const nRect = nCont.getBoundingClientRect(), nScale = Math.min(nRect.width / img.w, nRect.height / img.h), nX = (nRect.width - img.w * nScale) / 2, nY = (nRect.height - img.h * nScale) / 2;
            navImg.style.transform = `translate(${nX}px, ${nY}px) scale(${nScale})`;
            
            const fW = (crop.w / view.scale * nScale), fH = (crop.h / view.scale * nScale);
            const imgCX = nX + (img.w * nScale) / 2, imgCY = nY + (img.h * nScale) / 2;
            const relCX = (crop.x + crop.w/2 - view.x) / view.scale - img.w/2, relCY = (crop.y + crop.h/2 - view.y) / view.scale - img.h/2;
            
            navBox.style.width = fW + 'px'; navBox.style.height = fH + 'px';
            navBox.style.left = (imgCX + relCX * nScale - fW/2 - 3) + 'px';
            navBox.style.top = (imgCY + relCY * nScale - fH/2 - 3) + 'px';
        }
    </script>
</body>
</html>
